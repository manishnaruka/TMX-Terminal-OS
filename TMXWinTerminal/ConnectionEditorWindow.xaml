<Window x:Class="TMXWinTerminal.ConnectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Icon="Assets/tmx-logo.png"
        Height="700"
        Width="760"
        MinHeight="620"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg}"
        FontFamily="Segoe UI"
        FontSize="13"
        Loaded="Window_OnLoaded">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="16,5">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" />
        </Border>
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Margin="0,0,6,0" />
                <Button Content="Save" Style="{StaticResource PrimaryButton}" IsDefault="True" Click="SaveButton_OnClick" />
            </StackPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14">
                <GroupBox Header="Connection Details">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Name" FontWeight="SemiBold" />
                        <Label Grid.Row="0" Grid.Column="1" Content="Host / IP" FontWeight="SemiBold" Margin="8,0,0,0" />
                        <TextBox x:Name="NameTextBox" Grid.Row="1" Grid.Column="0" Text="{Binding Entry.Name, UpdateSourceTrigger=PropertyChanged}" Margin="2,2,4,8" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Entry.Host, UpdateSourceTrigger=PropertyChanged}" Margin="8,2,2,8" />
                        <Label Grid.Row="2" Grid.Column="0" Content="Username" FontWeight="SemiBold" />
                        <Label Grid.Row="2" Grid.Column="1" Content="Port" FontWeight="SemiBold" Margin="8,0,0,0" />
                        <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding Entry.Username, UpdateSourceTrigger=PropertyChanged}" Margin="2,2,4,8" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Entry.Port, UpdateSourceTrigger=PropertyChanged}" Margin="8,2,2,8" />
                        <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="PEM / Private Key Path" FontWeight="SemiBold" />
                        <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Entry.PemFilePath, UpdateSourceTrigger=PropertyChanged}" Margin="2,2,6,2" />
                            <Button Grid.Column="1" Content="Browse" Command="{Binding BrowsePemCommand}" Margin="0,2,4,2" />
                            <Button Grid.Column="2" Content="Open Folder" Command="{Binding OpenPemFolderCommand}" Margin="0,2,0,2" />
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Header="SSH Command">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Generate SSH Command" Command="{Binding GenerateCommand}" Margin="0,0,4,0" />
                            <Button Content="Copy Command" Command="{Binding CopyCommand}" />
                        </StackPanel>
                        <TextBox Text="{Binding Entry.SshCommand, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="100"
                                 TextWrapping="Wrap" />
                    </DockPanel>
                </GroupBox>

                <GroupBox Header="Notes">
                    <TextBox Text="{Binding Entry.Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Height="120"
                             TextWrapping="Wrap" />
                </GroupBox>

                <GroupBox Header="Resolved Command Preview">
                    <TextBox Text="{Binding ResolvedCommandPreview, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Height="100"
                             TextWrapping="Wrap" />
                </GroupBox>

                <GroupBox Header="Metadata">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Created" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Entry.CreatedAt, Converter={StaticResource UtcToLocalConverter}}" Style="{StaticResource MutedText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Updated" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Entry.UpdatedAt, Converter={StaticResource UtcToLocalConverter}}" Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
