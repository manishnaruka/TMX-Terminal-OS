<Window x:Class="TMXWinTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:TMXWinTerminal.Helpers"
        mc:Ignorable="d"
        Title="TMXWinTerminal"
        Height="760"
        Width="1200"
        MinHeight="650"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <helpers:UtcToLocalConverter x:Key="UtcToLocalConverter" />

        <SolidColorBrush x:Key="Bg" Color="#F3F3F3" />
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF" />
        <SolidColorBrush x:Key="Border" Color="#E0E0E0" />
        <SolidColorBrush x:Key="BorderFocus" Color="#0078D4" />
        <SolidColorBrush x:Key="Accent" Color="#0078D4" />
        <SolidColorBrush x:Key="AccentHover" Color="#106EBE" />
        <SolidColorBrush x:Key="AccentText" Color="White" />
        <SolidColorBrush x:Key="Danger" Color="#C42B1C" />
        <SolidColorBrush x:Key="DangerBg" Color="#FDE7E9" />
        <SolidColorBrush x:Key="Text" Color="#1A1A1A" />
        <SolidColorBrush x:Key="Muted" Color="#6E6E6E" />
        <SolidColorBrush x:Key="Hover" Color="#E9E9E9" />
        <SolidColorBrush x:Key="InputBg" Color="#FFFFFF" />

        <!-- TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <!-- Label -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Padding" Value="2,4,2,2" />
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderFocus}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Hover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Border}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="{StaticResource AccentText}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
            <Setter Property="Foreground" Value="{StaticResource Danger}" />
        </Style>

        <!-- ComboBox: keep default template, just style the basics -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <!-- GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{StaticResource Panel}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        Background="{StaticResource Bg}"
                                        CornerRadius="6,6,0,0"
                                        Padding="12,8">
                                    <ContentPresenter ContentSource="Header">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="{StaticResource Text}" />
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                </Border>
                                <ContentPresenter Margin="{TemplateBinding Padding}" />
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView -->
        <Style TargetType="ListView">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- GridViewColumnHeader -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <!-- ListViewItem -->
        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Row"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="{StaticResource Hover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#DCECFC" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Modifiers="Control" Key="D" Command="{Binding DuplicateCommand}" />
        <KeyBinding Key="F5" Command="{Binding ConnectCommand}" />
        <KeyBinding Modifiers="Alt" Key="Enter" Command="{Binding ConnectCommand}" />
    </Window.InputBindings>
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Connect" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" />
                <ComboBox DockPanel.Dock="Right" Width="160" ItemsSource="{Binding TerminalPreferences}" SelectedItem="{Binding SelectedTerminalPreference}" VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Text="Terminal:" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="{StaticResource Muted}" />
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Muted}" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="16,5">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" />
        </Border>
        <!-- Main content -->
        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Left panel: connections list -->
            <GroupBox Grid.Column="0" Header="Saved Connections" Margin="0,0,6,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap" Style="{StaticResource MutedText}"
                               Text="Double-click to connect. Filter by name, host, user, notes, or command." />
                    <ListView x:Name="EntriesListView"
                              ItemsSource="{Binding EntriesView}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                              MouseDoubleClick="EntriesListView_OnMouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="110" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Host" Width="100" DisplayMemberBinding="{Binding Host}" />
                                <GridViewColumn Header="User" Width="75" DisplayMemberBinding="{Binding Username}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </GroupBox>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True" />
            <!-- Right panel: details -->
            <Grid Grid.Column="2" Margin="6,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="Connection Details">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Name" FontWeight="SemiBold" />
                                <Label Grid.Row="0" Grid.Column="1" Content="Host / IP" FontWeight="SemiBold" Margin="8,0,0,0" />
                                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding CurrentEntry.Name, UpdateSourceTrigger=PropertyChanged}" Margin="2,2,4,8" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CurrentEntry.Host, UpdateSourceTrigger=PropertyChanged}" Margin="8,2,2,8" />
                                <Label Grid.Row="2" Grid.Column="0" Content="Username" FontWeight="SemiBold" />
                                <Label Grid.Row="2" Grid.Column="1" Content="Port" FontWeight="SemiBold" Margin="8,0,0,0" />
                                <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding CurrentEntry.Username, UpdateSourceTrigger=PropertyChanged}" Margin="2,2,4,8" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrentEntry.Port, UpdateSourceTrigger=PropertyChanged}" Margin="8,2,2,8" />
                                <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="PEM / Private Key Path" FontWeight="SemiBold" />
                                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding CurrentEntry.PemFilePath, UpdateSourceTrigger=PropertyChanged}" Margin="2,2,6,2" />
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowsePemCommand}" Margin="0,2,4,2" />
                                    <Button Grid.Column="2" Content="Open Folder" Command="{Binding OpenPemFolderCommand}" Margin="0,2,0,2" />
                                </Grid>
                            </Grid>
                        </GroupBox>
                        <GroupBox Header="SSH Command">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="Generate SSH Command" Command="{Binding GenerateCommand}" Margin="0,0,4,0" />
                                    <Button Content="Copy Command" Command="{Binding CopyCommand}" />
                                </StackPanel>
                                <TextBox Text="{Binding CurrentEntry.SshCommand, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Height="100"
                                         TextWrapping="Wrap" />
                            </DockPanel>
                        </GroupBox>
                        <GroupBox Header="Notes">
                            <TextBox Text="{Binding CurrentEntry.Notes, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="100"
                                     TextWrapping="Wrap" />
                        </GroupBox>
                        <GroupBox Header="Resolved Command Preview">
                            <TextBlock Text="{Binding ResolvedCommandPreview}" TextWrapping="Wrap" Style="{StaticResource MutedText}" />
                        </GroupBox>
                        <GroupBox Header="Metadata">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Created" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding CurrentEntry.CreatedAt, Converter={StaticResource UtcToLocalConverter}}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Updated" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding CurrentEntry.UpdatedAt, Converter={StaticResource UtcToLocalConverter}}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
                <!-- Action bar -->
                <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="New" Command="{Binding NewCommand}" Margin="0,0,4,0" />
                        <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,4,0" />
                        <Button Content="Duplicate" Command="{Binding DuplicateCommand}" Margin="0,0,4,0" />
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,4,0" />
                        <Button Content="Connect" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
