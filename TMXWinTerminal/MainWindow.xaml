<Window x:Class="TMXWinTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TMXWinTerminal"
        Icon="Assets/tmx-logo.png"
        Height="680"
        Width="920"
        MinHeight="560"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Bg}"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Control" Key="E" Command="{Binding EditCommand}" />
        <KeyBinding Modifiers="Control" Key="D" Command="{Binding DuplicateCommand}" />
        <KeyBinding Key="F5" Command="{Binding ConnectCommand}" />
        <KeyBinding Modifiers="Alt" Key="Enter" Command="{Binding ConnectCommand}" />
    </Window.InputBindings>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Source="Assets/tmx-logo.png"
                       Width="28"
                       Height="28"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="TMXWinTerminal"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="15" />
                <TextBlock Grid.Column="3" Text="Search:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource Muted}" />
                <TextBox Grid.Column="4"
                         Width="280"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         ToolTip="Filter by name, host, username, notes, or SSH command" />
                <Button Grid.Column="6"
                        Content="{Binding ThemeLabel}"
                        Command="{Binding ToggleThemeCommand}"
                        Margin="12,0,0,0"
                        ToolTip="Toggle light / dark theme" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="16,5">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" />
        </Border>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Saved Connections">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1,1,1,0" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                        <WrapPanel>
                            <Button Content="New" Command="{Binding NewCommand}" Margin="0,0,6,6" />
                            <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,6,6" />
                            <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,6,6" />
                            <Button Content="Connect" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,6" />
                        </WrapPanel>
                    </Border>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedText}"
                               Text="Double-click any saved SSH entry to launch it. Add and edit now open in a modal." />
                    <ListView x:Name="EntriesListView"
                              ItemsSource="{Binding EntriesView}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                              MouseDoubleClick="EntriesListView_OnMouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="118" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Host" Width="120" DisplayMemberBinding="{Binding Host}" />
                                <GridViewColumn Header="User" Width="82" DisplayMemberBinding="{Binding Username}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </GroupBox>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding SelectionHint}" Style="{StaticResource MutedText}" Margin="0,0,0,10" TextWrapping="Wrap" />

                    <GroupBox Header="Selected Connection">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Host / IP" FontWeight="SemiBold" Margin="12,0,0,0" />
                            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding CurrentEntry.Name, Mode=OneWay}" IsReadOnly="True" Margin="0,4,6,10" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CurrentEntry.Host, Mode=OneWay}" IsReadOnly="True" Margin="6,4,0,10" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Username" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Port" FontWeight="SemiBold" Margin="12,0,0,0" />
                            <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding CurrentEntry.Username, Mode=OneWay}" IsReadOnly="True" Margin="0,4,6,10" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrentEntry.Port, Mode=OneWay}" IsReadOnly="True" Margin="6,4,0,10" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="PEM / Private Key Path" FontWeight="SemiBold" />
                            <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding CurrentEntry.PemFilePath, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,0" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Notes">
                        <TextBox Text="{Binding CurrentEntry.Notes, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="110"
                                 TextWrapping="Wrap" />
                    </GroupBox>

                    <GroupBox Header="Resolved Command Preview">
                        <DockPanel>
                            <Button DockPanel.Dock="Top" Content="Copy Command" Command="{Binding CopyCommand}" HorizontalAlignment="Right" Margin="0,0,0,6" />
                            <TextBox Text="{Binding ResolvedCommandPreview, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="110"
                                     TextWrapping="Wrap" />
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Metadata">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Created" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding CurrentEntry.CreatedAt, Converter={StaticResource UtcToLocalConverter}}" Style="{StaticResource MutedText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Updated" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding CurrentEntry.UpdatedAt, Converter={StaticResource UtcToLocalConverter}}" Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
